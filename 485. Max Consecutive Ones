class Solution:
    def findMaxConsecutiveOnes(self, nums: List[int]) -> int:
        count = 0
        n = len(nums)
        m=0

        for j in range (0,n):
            if nums[j] ==1:
                count+=1
                m=max(m,count)
                
            else:
                count=0
        
        return m

