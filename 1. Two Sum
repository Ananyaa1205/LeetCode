class Solution: ## BRUTE FORCE
    def twoSum(self, nums: List[int], target: int) -> List[int]:
        n = len(nums)
        for i in range(0,n):
            for j in range(i+1,n):
                if nums[i]+nums[j] == target:
                     return [i,j]

               
class Solution: ## OPTIMAL
    def twoSum(self, nums: List[int], target: int) -> List[int]:
        dict = {}
        for i in range(len(nums)):
            need = target - nums[i]
            if need in dict:
                return [dict[need],i]
            
            dict[nums[i]] = i
